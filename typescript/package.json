{
  "name": "revenant-sign",
  "version": "2.0.0",
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
  "description": "Cross-platform client for ARX CoSign electronic signatures via SOAP API",
  "license": "Apache-2.0",
  "author": "Aleksandr Kraiz",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "revenant": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-fonts.cjs",
    "dev": "tsx bin/revenant.ts",
    "prepublishOnly": "pnpm build && pnpm typecheck && pnpm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --fix src/ tests/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "asn1js": "^3.0.10",
    "commander": "^15.0.0",
    "fast-xml-parser": "^5.10.1",
    "jpeg-js": "^0.4.4",
    "node-forge": "^1.4.0",
    "pdf-lib": "^1.17.1",
    "pkijs": "^3.4.0",
    "pngjs": "^7.0.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^22.19.21",
    "@types/node-forge": "^1.3.14",
    "@types/pngjs": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.10",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1"
    }
  },
  "keywords": [
    "revenant",
    "arx",
    "cosign",
    "electronic-signature",
    "digital-signature",
    "pdf-signing",
    "soap",
    "pkcs7",
    "cms",
    "oasis-dss"
  ],
  "homepage": "https://github.com/lobotomoe/revenant/tree/main/typescript#readme",
  "bugs": "https://github.com/lobotomoe/revenant/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/lobotomoe/revenant",
    "directory": "typescript"
  }
}
